{
 "name": "js-manim",
 "version": "0.1.0",
 "type": "module",
 "description": "Manim-style animations in JavaScript with CLI MP4/WebM output",
 "main": "src/index.js",
 "bin": {
  "manjs": "./bin/manjs"
 },
 "scripts": {
  "start": "node src/index.js",
  "test:2d": "node bin/manjs scenes/2d_demo.js output_2d.mp4",
  "test:3d": "node bin/manjs scenes/3d_demo.js output_3d.webm"
 },
 "keywords": [
  "manim",
  "animation",
  "cli",
  "mp4",
  "webm",
  "canvas",
  "three.js"
 ],
 "author": "Antonymwangi20",
 "license": "MIT",
 "dependencies": {
  "canvas": "^3.2.2",
  "canvas-record": "^5.5.1",
  "three": "^0.183.2",
  "three-software-renderer": "^1.1.0"
 },
 "devDependencies": {
  "ffmpeg-static": "^5.3.0"
 }
}
